{
  gateway: {
    port: 18789,
    mode: "local",
    bind: "loopback",
    auth: { mode: "token", token: "REPLACE_WITH_GENERATED_TOKEN" },
    reload: { mode: "hybrid" },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "anthropic/claude-sonnet-4-6",
        fallbacks: ["anthropic/claude-opus-4-6"],
      },
      userTimezone: "Europe/Lisbon",
      timeFormat: "24",
      heartbeat: {
        every: "30m",
        target: "last",
        model: "anthropic/claude-haiku-4-5",
      },
      subagents: {
        maxConcurrent: 4,
        maxSpawnDepth: 2,
        maxChildrenPerAgent: 5,
        model: "anthropic/claude-sonnet-4-6",
        thinking: "adaptive",
        runTimeoutSeconds: 300,
        archiveAfterMinutes: 60,
      },
      sandbox: {
        mode: "non-main",
        scope: "agent",
      },
    },

    list: [
      {
        id: "atlas",
        default: true,
        workspace: "~/.openclaw/workspace",
        identity: { name: "ATLAS", emoji: "⚙️", theme: "Precision engineering meets strategic AI delivery" },
        subagents: { allowAgents: ["*"] },
      },
      {
        id: "solutions-architect",
        workspace: "~/.openclaw/workspace-solutions-architect",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "Solutions Architect", emoji: "🏗️" },
        tools: { deny: ["cron", "gateway"] },
      },
      {
        id: "ai-engineer",
        workspace: "~/.openclaw/workspace-ai-engineer",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "AI Engineer", emoji: "🤖" },
        tools: { deny: ["cron", "gateway"] },
      },
      {
        id: "engineer-backend",
        workspace: "~/.openclaw/workspace-engineer-backend",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "Engineer (Backend)", emoji: "⚡" },
        tools: { deny: ["cron", "gateway"] },
      },
      {
        id: "engineer-frontend",
        workspace: "~/.openclaw/workspace-engineer-frontend",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "Engineer (Frontend)", emoji: "🎨" },
        tools: { deny: ["cron", "gateway"] },
      },
      {
        id: "qa-engineer",
        workspace: "~/.openclaw/workspace-qa-engineer",
        model: { primary: "anthropic/claude-haiku-4-5-20251001" },
        identity: { name: "QA Engineer", emoji: "🔍" },
        tools: { deny: ["cron", "gateway", "write", "edit", "apply_patch"] },
      },
      {
        id: "devops-engineer",
        workspace: "~/.openclaw/workspace-devops-engineer",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "DevOps Engineer", emoji: "🚀" },
        tools: { deny: ["gateway"] },
      },
      {
        id: "security-engineer",
        workspace: "~/.openclaw/workspace-security-engineer",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "Security Engineer", emoji: "🛡️" },
        tools: { deny: ["cron", "gateway", "write", "edit", "apply_patch"] },
      },
      {
        id: "ui-ux-designer",
        workspace: "~/.openclaw/workspace-ui-ux-designer",
        model: { primary: "anthropic/claude-sonnet-4-6" },
        identity: { name: "UI/UX Designer", emoji: "✨" },
        tools: { deny: ["cron", "gateway", "exec"] },
      },
      {
        id: "technical-writer",
        workspace: "~/.openclaw/workspace-technical-writer",
        model: { primary: "anthropic/claude-haiku-4-5-20251001" },
        identity: { name: "Technical Writer", emoji: "📝" },
        tools: { deny: ["cron", "gateway", "exec"] },
      },
      {
        id: "data-engineer",
        workspace: "~/.openclaw/workspace-data-engineer",
        model: { primary: "anthropic/claude-haiku-4-5-20251001" },
        identity: { name: "Data Engineer", emoji: "🔢" },
        tools: { deny: ["cron", "gateway"] },
      },
    ],
  },

  tools: {
    exec: { host: "sandbox", ask: "on-miss", security: "allowlist" },
    subagents: { tools: { deny: ["gateway", "cron"] } },
    sessions: { visibility: "tree" },
  },

  logging: { redactSensitive: "tools" },
}
